{
  "$schema": "https://schema.tauri.app/config/2",
  "app": {
    "windows": [
      {
        "title": "PiYTmusic",
        "width": 1280,
        "height": 720,
        "minWidth": 800,
        "minHeight": 360,
        "decorations": false,
        "resizable": true,
        "center": true,
        "backgroundColor": "#0a0a0a",
        "dragDropEnabled": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["deb"],
    "createUpdaterArtifacts": false,
    "category": "Music",
    "linux": {
      "deb": {
        "depends": [
          "gstreamer1.0-plugins-base",
          "gstreamer1.0-plugins-good",
          "gstreamer1.0-libav"
        ]
      }
    }
  }
}
